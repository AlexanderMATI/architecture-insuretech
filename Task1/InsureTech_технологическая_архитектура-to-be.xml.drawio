        <mxCell id="req-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#333333;" value="" vertex="1">
          <mxGeometry height="300" width="400" x="741" y="1660" as="geometry" />
