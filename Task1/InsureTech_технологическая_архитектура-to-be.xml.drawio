        <mxCell id="req-title" parent="1" style="text;html=1;align=center;verticalAlign=middle;" value="&lt;font style=&quot;font-size:18px;&quot;&gt;&lt;b&gt;Требования / Requirements&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="25" width="220" x="831" y="1670" as="geometry" />
        </mxCell>
        <mxCell id="req-text" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" value="&lt;div style=&quot;text-align:left;&quot;&gt;&lt;b&gt;Availability:&lt;/b&gt; 99.9%&lt;br&gt;&lt;b&gt;RTO:&lt;/b&gt; 45 min&lt;br&gt;&lt;b&gt;RPO:&lt;/b&gt; 15 min (achieved: ≈0 with sync replica)&lt;br&gt;&lt;br&gt;&lt;b&gt;Масштабирование:&lt;/b&gt;&lt;br&gt;• Горизонтальное (HPA по CPU/Memory/RPS)&lt;br&gt;• Multi-AZ deployment&lt;br&gt;• Node autoscaling (3-10 nodes per AZ)&lt;br&gt;&lt;br&gt;&lt;b&gt;Отказоустойчивость:&lt;/b&gt;&lt;br&gt;• Active-Active across 2 AZs&lt;br&gt;• PostgreSQL sync replication&lt;br&gt;• Automatic failover&lt;br&gt;• PITR backups to Object Storage&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="360" x="761" y="1700" as="geometry" />
        </mxCell>
        <mxCell id="arch-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#333333;" value="" vertex="1">
          <mxGeometry height="300" width="420" x="1171" y="1660" as="geometry" />
        </mxCell>
        <mxCell id="arch-title" parent="1" style="text;html=1;align=center;verticalAlign=middle;" value="&lt;font style=&quot;font-size:18px;&quot;&gt;&lt;b&gt;Архитектурные решения&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="25" width="220" x="1271" y="1670" as="geometry" />
        </mxCell>
        <mxCell id="arch-text" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" value="&lt;div style=&quot;text-align:left;&quot;&gt;&lt;b&gt;Kubernetes:&lt;/b&gt; 1 кластер MKS, растянутый&lt;br&gt;на 2 AZ (не независимые кластеры)&lt;br&gt;&lt;br&gt;&lt;b&gt;Причина:&lt;/b&gt; Упрощение управления,&lt;br&gt;единый control plane, объём данных 50GB&lt;br&gt;не требует шардирования&lt;br&gt;&lt;br&gt;&lt;b&gt;База данных:&lt;/b&gt; Managed PostgreSQL&lt;br&gt;без шардирования (50GB &amp;lt;&amp;lt; порога)&lt;br&gt;&lt;br&gt;&lt;b&gt;Failover стратегия:&lt;/b&gt; Active-Active&lt;br&gt;с автоматическим переключением&lt;br&gt;&lt;br&gt;&lt;b&gt;Балансировка:&lt;/b&gt; ALB → Ingress NGINX&lt;br&gt;с health checks на всех уровнях&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="380" x="1191" y="1700" as="geometry" />
        </mxCell>
        <mxCell id="hc-alb" parent="1" style="text;html=1;align=center;verticalAlign=middle;fillColor=#fff;strokeColor=#82b366;rounded=1;fontSize=10;" value="⚕️ Health Check" vertex="1">
